<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material 3 (Material You) Theme - Sleek Dark Orange/Grey -->
    <style name="Theme.TimeToGo" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>

        <!-- Custom attributes for status cards -->
        <item name="statusActiveColor">@color/status_active</item>
        <item name="statusInactiveColor">@color/status_inactive</item>

        <!-- Status & Navigation bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Default Card styling for the sleek feel -->
        <item name="materialCardViewStyle">@style/Widget.TimeToGo.CardView</item>
    </style>

    <!-- Sleek Custom Cards -->
    <style name="Widget.TimeToGo.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardElevation">2dp</item>
        <item name="cornerFamily">rounded</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Sign-In screen theme -->
    <style name="Theme.TimeToGo.SignIn" parent="Theme.TimeToGo">
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Theme for Google Places Autocomplete Activity -->
    <style name="PlacesAutocompleteTheme" parent="Theme.TimeToGo">
    </style>
</resources>
